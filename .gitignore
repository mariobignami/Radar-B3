# Python
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
.env

# Dados
# data/raw fica versionado porque o deploy do Streamlit precisa da base local.
data/processed/*.csv
!data/raw/.gitkeep
!data/processed/.gitkeep

# Modelos
